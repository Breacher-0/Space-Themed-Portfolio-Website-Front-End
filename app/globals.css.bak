@tailwind base;
@tailwind components;
@tailwind utilities;

@layer components {
  /* Layout */
  .layout-html {
    @apply scroll-smooth;
  }
  .layout-body {
    @apply bg-slate-950 text-white overflow-y-scroll overflow-x-hidden antialiased;
  }

  /* Page */
  .hero-main {
    @apply min-h-screen pt-24 px-10;
  }
  .hero-title {
    @apply text-4xl font-bold;
  }

  /* Navbar */
  .navbar-wrapper {
    @apply fixed top-0 z-50 w-full h-16 bg-slate-950/60 backdrop-blur-md border-b border-purple-900/30 shadow-lg px-8;
  }
  .navbar-container {
    @apply flex items-center justify-between w-full h-full max-w-7xl mx-auto;
  }
  .navbar-brand {
    @apply flex items-center gap-3;
  }
  .navbar-logo {
    @apply hover:rotate-180 transition-transform duration-500 ease-in-out;
  }
  .navbar-title {
    @apply hidden md:block font-bold text-gray-200 text-lg tracking-wide;
  }
  .navbar-links {
    @apply hidden md:flex items-center gap-8 border border-purple-800/40 bg-black/40 px-6 py-2 rounded-full text-gray-300;
  }
  .navbar-link {
    @apply hover:text-white hover:scale-105 transition-all;
  }
  .navbar-socials {
    @apply flex items-center gap-4;
  }
  .social-icon {
    @apply hover:scale-110 opacity-80 hover:opacity-100 transition-all;
  }

  /* Footer */
  .footer-wrapper {
    @apply w-full bg-slate-950/80 text-gray-300 py-10 border-t border-purple-900/30 mt-20;
  }
  .footer-container {
    @apply max-w-7xl mx-auto flex flex-col items-center px-4;
  }
  .footer-grid {
    @apply grid grid-cols-1 md:grid-cols-2 gap-12 w-full max-w-3xl;
  }
  .footer-column {
    @apply flex flex-col items-center;
  }
  .footer-title {
    @apply font-bold text-white text-lg mb-6;
  }
  .footer-link {
    @apply flex items-center gap-3 hover:text-white opacity-80 hover:opacity-100 transition-all mb-4;
  }
  .footer-link-text {
    @apply text-sm tracking-wide;
  }
  .footer-contact {
    @apply flex items-center gap-2 text-sm opacity-80 mb-4 tracking-wide;
  }
  .footer-contact-link {
    @apply hover:text-white hover:opacity-100 transition-all;
  }
  .footer-copy {
    @apply mt-16 text-sm text-gray-500 tracking-wider;
  }
}
